# .env.example — Copy to .env and fill in your values.
#
# This file is for running the quickymesh API server DIRECTLY on the host
# (i.e. without Docker). Docker users should configure docker/.env instead.
#
# The server reads this file automatically on startup via python-dotenv.

# ---- Concept art --------------------------------------------------------
#
# Required if using the Gemini concept art backend.
# Get a key at: https://aistudio.google.com/
# Leave blank (or omit) if using FLUX.1 [dev] only.
GEMINI_API_KEY=

# ---- ComfyUI -----------------------------------------------------------
#
# URL of your running ComfyUI instance.
# Default is http://localhost:8190 (matches the Docker container).
# Change to http://localhost:8188 if using a non-Docker portable install.
COMFYUI_URL=http://localhost:8190

# Directory where ComfyUI writes output files (images, GLBs).
# Must be set for the server to find generated files.
# Example for a Windows portable install:
#   COMFYUI_OUTPUT_DIR=C:/path/to/ComfyUI_windows_portable/ComfyUI/output
# For Docker this is set automatically — leave blank here.
COMFYUI_OUTPUT_DIR=

# ---- Blender -----------------------------------------------------------
#
# Path to the Blender executable. Only needed for non-Docker setups.
# Docker users: Blender is installed in the container — leave blank.
# Windows example:
#   BLENDER_PATH=C:/Program Files/Blender Foundation/Blender 4.5/blender.exe
# Linux example:
#   BLENDER_PATH=/usr/bin/blender
BLENDER_PATH=

# ---- Auth --------------------------------------------------------------
#
# Single-user API key mode. Any non-empty string works.
# Alternatively, create users.yaml (see users.yaml.example) for multi-user mode.
API_KEY=change-me-secret-key
