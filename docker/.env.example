# docker/.env.example — Copy this to docker/.env and fill in your values.
#
# ---- Auth ---------------------------------------------------------------
#
# Single-user mode: set API_KEY to a secret string.
# The CLI and any HTTP client must send:  Authorization: Bearer <API_KEY>
#
# Multi-user mode: create users.yaml from users.yaml.example (repo root),
# then uncomment the users.yaml volume mount in docker-compose.yml.

API_KEY=change-me-secret-key

# ---- Concept art backends -----------------------------------------------
#
# Required if using the Gemini concept art backend.
# Get a key at: https://aistudio.google.com/
# Leave blank to use FLUX.1 [dev] (local, no API key required).

GEMINI_API_KEY=

# ---- Model paths ---------------------------------------------------------
#
# TRELLIS_MODELS_DIR — mounted into the container at /app/models.
# All workflows (FLUX, ControlNet restyle, Trellis) share this directory.
#
# Option A: Point at an existing AI models folder to avoid re-downloading
#   TRELLIS_MODELS_DIR=/home/YOU/AI_Models
#
# Option B: Leave unset — defaults to docker/models/trellis (repo-relative).
#   Run `bash docker/download_models.sh` to populate it first.

TRELLIS_MODELS_DIR=

# ---- quickymesh pipeline data -------------------------------------------
#
# QUICKYMESH_PIPELINE_ROOT — where pipeline state, assets, and the SQLite
# task queue are stored.  Defaults to docker/pipeline_root (repo-relative).
# Set to an absolute path for a custom location.

QUICKYMESH_PIPELINE_ROOT=

# ---- (Advanced) Override container defaults ------------------------------
# Uncomment only if you need to change these from the built-in values.

# QUICKYMESH_LOGS_DIR=./logs
# TRELLIS_OUTPUT_DIR=./output/trellis
# TRELLIS_INPUT_DIR=./input/trellis
