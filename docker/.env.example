# docker/.env.example — Copy this to docker/.env and fill in your paths.
#
# TRELLIS_MODELS_DIR — models for the comfyui-trellis container.
#   All workflows (FLUX, ControlNet restyle, Trellis) run in this container.
#
# Option A: Point at an existing AI models folder to avoid re-downloading
#   TRELLIS_MODELS_DIR=/home/YOU/AI_Models
#
# Option B: Leave unset — defaults to repo-relative ./models/trellis
#   Run `bash docker/download_models.sh flux restyle` to populate it,
#   then `docker compose up comfyui-trellis` (Trellis weights download automatically).

TRELLIS_MODELS_DIR=
