# docker/.env.example — Copy this to docker/.env and set your paths.
#
# Option A: Central shared folder (avoids duplicate model files)
#   SDXL_MODELS_DIR=C:/Users/YOU/AI_Models
#   TRELLIS_MODELS_DIR=C:/Users/YOU/AI_Models
#
# Option B: Separate folders per container
#   SDXL_MODELS_DIR=C:/Users/YOU/ComfyUI/models
#   TRELLIS_MODELS_DIR=C:/Users/YOU/ComfyUI_Trellis/models
#
# Option C: Leave unset — defaults to repo-relative ./models/sdxl and ./models/trellis
#   (run bash docker/download_models.sh first)

SDXL_MODELS_DIR=
TRELLIS_MODELS_DIR=
